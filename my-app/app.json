{
  "expo": {
    "name": "my-app",
    "slug": "my-app",
    "owner": "zxn3",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zhengning.dualcamera",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "需要访问相机以进行全屏预览与拍照。",
        "NSMicrophoneUsageDescription": "需要访问麦克风以录制视频声音。"
      },
      "buildNumber": "21"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.zhengning.dualcamera"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "需要访问相册以保存你拍摄的照片。",
          "savePhotosPermission": "需要授权以将照片保存到系统相册。",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "./plugin/withDualCamera"
    ],
    "extra": {
      "eas": {
        "projectId": "0016cc3f-43da-4d85-9508-ed99d78fb262"
      }
    }
  }
}
